+// Custom type trait for Ptr<T> to replace std::remove_pointer specialization
+// Emscripten's libc++ forbids specializing std::remove_pointer
+namespace Cangjie {
+template <class T> struct RemovePtrPointer {
+    using type = T;
+};
+template <class T> struct RemovePtrPointer<Ptr<T>> {
+    using type = T;
+};
+template <class T> using RemovePtrPointer_t = typename RemovePtrPointer<T>::type;
+} // namespace Cangjie
+
+#ifndef __EMSCRIPTEN__
+// Only specialize std::remove_pointer for non-Emscripten builds
 template <class T> struct std::remove_pointer<Ptr<T>> {
     using type = T;
 };
+#endif
 
 #endif
