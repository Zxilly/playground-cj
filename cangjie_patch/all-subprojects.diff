@@ -0,0 +1,109 @@
+// Copyright (c) Huawei Technologies Co., Ltd. 2025. All rights reserved.
+// This source file is part of the Cangjie project, licensed under Apache-2.0
+// with Runtime Library Exception.
+//
+// See https://cangjie-lang.cn/pages/LICENSE for license information.
+
+#ifndef LSPSERVER_WASMTRANSPORT_H
+#define LSPSERVER_WASMTRANSPORT_H
+
+#ifdef BUILD_WASM
+
+#include <iostream>
+#include <sstream>
+#include <queue>
+#include <mutex>
+#include <condition_variable>
+
+#include <emscripten.h>
+#include <emscripten/bind.h>
+
+#include "../json-rpc/Transport.h"
+
+namespace ark {
+
+// Callback function type for sending messages to JavaScript
+using JsMessageCallback = void (*)(const char *);
+
+class WasmTransport : public Transport {
+public:
+    static WasmTransport &Instance()
+    {
+        static WasmTransport instance{};
+        return instance;
+    }
+
+    // Transport interface implementation
+    void SetIO(std::FILE *in, std::FILE *out) override
+    {
+        // Not used in WASM - communication is via embind
+    }
+
+    void Notify(std::string method, ValueOrError params) override;
+
+    void Reply(nlohmann::json id, ValueOrError result) override;
+
+    LSPRet Loop(MessageHandler &handler) override;
+
+    // JavaScript interface methods
+    void ReceiveMessage(const std::string &message);
+
+    // Set the callback for sending messages to JavaScript
+    void SetMessageCallback(JsMessageCallback callback)
+    {
+        jsCallback = callback;
+    }
+
+    // Process a single message (non-blocking, for use with embind)
+    LSPRet ProcessSingleMessage(MessageHandler &handler);
+
+    // Check if there are pending messages
+    bool HasPendingMessages() const
+    {
+        std::lock_guard<std::mutex> lock(queueMutex);
+        return !messageQueue.empty();
+    }
+
+    // Request exit from the message loop
+    void RequestExit()
+    {
+        exitRequested = true;
+        queueCondition.notify_all();
+    }
+
+    ~WasmTransport() override {}
+
+private:
+    WasmTransport() : jsCallback(nullptr), exitRequested(false) {}
+    WasmTransport(const WasmTransport &) = delete;
+    const WasmTransport &operator=(const WasmTransport &) = delete;
+
+    // Send a JSON message to JavaScript
+    void SendToJS(const nlohmann::json &message);
+
+    // Handle a parsed JSON message
+    LSPRet HandleMessage(nlohmann::json message, MessageHandler &handler);
+
+    // Encode error to JSON
+    static nlohmann::json EncodeError(const MessageErrorDetail &errorInfo);
+
+    // Decode error from JSON
+    static MessageErrorDetail DecodeError(const nlohmann::json &o);
+
+    // Message queue for receiving messages from JavaScript
+    std::queue<std::string> messageQueue;
+    mutable std::mutex queueMutex;
+    std::condition_variable queueCondition;
+
+    // Callback to send messages to JavaScript
+    JsMessageCallback jsCallback;
+
+    // Flag to request exit from Loop
+    std::atomic<bool> exitRequested;
+};
+
+} // namespace ark
+
+#endif // BUILD_WASM
+
+#endif // LSPSERVER_WASMTRANSPORT_H
