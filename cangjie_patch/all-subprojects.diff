diff --git a/cangjie_compiler/CMakeLists.txt b/cangjie_compiler/CMakeLists.txt
index 55796a39..045608b3 100644
--- a/cangjie_compiler/CMakeLists.txt
+++ b/cangjie_compiler/CMakeLists.txt
@@ -66,6 +66,38 @@ option(CANGJIE_WRITE_PROFILE "`--profile-compile-time` and `--profile-compile-me
 option(CANGJIE_ENABLE_ASAN_COV "build with asan and sanitize-coverage, used for cjc_fuzz and lsp_test" OFF)
 option(CANGJIE_VISIBLE_OPTIONS_ONLY "open CANGJIE_VISIBLE_OPTIONS_ONLY to only build options that are visible to users" ON)
 option(CANGJIE_USE_OH_LLVM_REPO "use OpenHarmony llvm repo with Cangjie llvm patch instead of cangjie llvm repo for building" OFF)
+
+# WASM 编译选项
+option(BUILD_WASM "Build WebAssembly version using Emscripten" OFF)
+
+if(BUILD_WASM)
+    message(STATUS "Building for WebAssembly target with pthreads and PROXY_TO_PTHREAD")
+
+    # WASM 不支持 CJNATIVE 后端（包含 LLVM 代码生成）
+    set(CANGJIE_CODEGEN_CJNATIVE_BACKEND OFF CACHE BOOL "" FORCE)
+    set(CANGJIE_BUILD_CJC OFF CACHE BOOL "" FORCE)
+    set(CANGJIE_BUILD_TESTS OFF CACHE BOOL "" FORCE)
+    set(CANGJIE_BUILD_STD_SUPPORT ON CACHE BOOL "" FORCE)
+
+    add_definitions(-DBUILD_WASM)
+    add_definitions(-DWASM_TARGET)
+
+    # ========== 编译器标志 (compile-time) ==========
+    # WASM 特性优化
+    set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -mbulk-memory")
+    set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -mreference-types")
+    set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -msimd128")
+    set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -matomics")
+    set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -pthread")
+
+    # Use native WebAssembly exceptions
+    set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -fwasm-exceptions")
+
+    # Size-first optimization with LTO for WASM
+    set(CMAKE_CXX_FLAGS_RELEASE "-Os -flto -DNDEBUG")
+    set(CMAKE_C_FLAGS_RELEASE   "-Os -flto -DNDEBUG")
+endif()
+
 set(CANGJIE_LLVM_BUILD_TYPE Default CACHE STRING "Build type for llvm")
 set(CANGJIE_CJDB_BUILD_TYPE Default CACHE STRING "Build type for cjdb")
 
@@ -374,6 +406,10 @@ add_subdirectory(third_party)
 if(CANGJIE_CODEGEN_CJNATIVE_BACKEND)
 add_subdirectory(schema)
 add_subdirectory(src)
+elseif(BUILD_WASM)
+# For WASM build, we need schema for FlatBuffers headers and src for cangjie-lsp-wasm target
+add_subdirectory(schema)
+add_subdirectory(src)
 endif()
 if(CANGJIE_BUILD_CJC)
     add_subdirectory(utils)
