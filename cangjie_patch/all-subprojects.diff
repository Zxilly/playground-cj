diff --git a/cangjie_tools/cangjie-language-server/src/wasm/WasmTransport.cpp b/cangjie_tools/cangjie-language-server/src/wasm/WasmTransport.cpp
new file mode 100644
index 00000000..336894c4
--- /dev/null
+++ b/cangjie_tools/cangjie-language-server/src/wasm/WasmTransport.cpp
@@ -0,0 +1,231 @@
+// Copyright (c) Huawei Technologies Co., Ltd. 2025. All rights reserved.
+// This source file is part of the Cangjie project, licensed under Apache-2.0
+// with Runtime Library Exception.
+//
+// See https://cangjie-lang.cn/pages/LICENSE for license information.
+
+#ifdef BUILD_WASM
+
+#include "WasmTransport.h"
+#include "../languageserver/capabilities/shutdown/Shutdown.h"
+#include "../languageserver/logger/Logger.h"
+
+namespace ark {
+
+nlohmann::json WasmTransport::EncodeError(const MessageErrorDetail &errorInfo)
+{
+    nlohmann::json root;
+    root["message"] = errorInfo.message;
+    root["code"] = static_cast<int64_t>(errorInfo.code);
+    return root;
+}
+
+MessageErrorDetail WasmTransport::DecodeError(const nlohmann::json &o)
+{
+    std::string msg = o.contains("message") ? o.value("message", "") : "Unspecified error";
+    ErrorCode code = o.contains("code") ? ErrorCode(o.value("code", -1)) : ErrorCode::UNKNOWN_ERROR_CODE;
+    return {msg, code};
+}
+
+void WasmTransport::Notify(std::string method, ValueOrError params)
+{
+    nlohmann::json root;
+    root["jsonrpc"] = "2.0";
+    root["method"] = method;
+    if (params.type == ValueOrErrorCheck::VALUE) {
+        root["params"] = std::move(params.jsonValue);
+    } else {
+        root["error"] = EncodeError(params.errorInfo);
+    }
+    SendToJS(root);
+}
+
+void WasmTransport::Reply(nlohmann::json id, ValueOrError result)
+{
+    nlohmann::json root;
+    root["jsonrpc"] = "2.0";
+    root["id"] = std::move(id);
+    if (result.type == ValueOrErrorCheck::VALUE) {
+        root["result"] = std::move(result.jsonValue);
+    } else {
+        root["error"] = EncodeError(result.errorInfo);
+    }
+    SendToJS(root);
+}
+
+void WasmTransport::SendToJS(const nlohmann::json &message)
+{
+    std::stringstream log;
+    std::ostringstream os;
+    os << message.dump(-1, ' ', false, nlohmann::json::error_handler_t::ignore);
+
+    std::string msgStr = os.str();
+
+    CleanAndLog(log, "send message body:" + msgStr);
+    Logger::Instance().LogMessage(MessageType::MSG_INFO, log.str());
+
+    // Use the registered callback to send message to JavaScript
+    if (jsCallback) {
+        jsCallback(msgStr.c_str());
+    }
+}
+
+void WasmTransport::ReceiveMessage(const std::string &message)
+{
+    std::lock_guard<std::mutex> lock(queueMutex);
+    messageQueue.push(message);
+    queueCondition.notify_one();
+}
+
+LSPRet WasmTransport::ProcessSingleMessage(MessageHandler &handler)
+{
+    Logger &logger = Logger::Instance();
+    std::stringstream log;
+
+    std::string json;
+    {
+        std::lock_guard<std::mutex> lock(queueMutex);
+        if (messageQueue.empty()) {
+            return LSPRet::SUCCESS;
+        }
+        json = messageQueue.front();
+        messageQueue.pop();
+    }
+
+    if (json.empty()) {
+        return LSPRet::SUCCESS;
+    }
+
+    CleanAndLog(log, "receive message body:" + json);
+    logger.LogMessage(MessageType::MSG_INFO, log.str());
+    logger.CollectMessageInfo(logger.LogInfo(MessageType::MSG_INFO, json));
+
+    nlohmann::json doc;
+#ifndef NO_EXCEPTIONS
+    try {
+#endif
+        doc = nlohmann::json::parse(json);
+#ifndef NO_EXCEPTIONS
+    } catch (nlohmann::detail::parse_error &errs) {
+        CleanAndLog(log, errs.what());
+        logger.LogMessage(MessageType::MSG_WARNING, log.str());
+        return LSPRet::ERR_JSON;
+    }
+#endif
+
+    return HandleMessage(std::move(doc), handler);
+}
+
+LSPRet WasmTransport::Loop(MessageHandler &handler)
+{
+    Logger &logger = Logger::Instance();
+    std::stringstream log;
+
+    while (!exitRequested) {
+        std::string json;
+        {
+            std::unique_lock<std::mutex> lock(queueMutex);
+            queueCondition.wait(lock, [this] {
+                return !messageQueue.empty() || exitRequested;
+            });
+
+            if (exitRequested && messageQueue.empty()) {
+                break;
+            }
+
+            if (!messageQueue.empty()) {
+                json = messageQueue.front();
+                messageQueue.pop();
+            }
+        }
+
+        if (json.empty()) {
+            continue;
+        }
+
+        CleanAndLog(log, "receive message body:" + json);
+        logger.LogMessage(MessageType::MSG_INFO, log.str());
+        logger.CollectMessageInfo(logger.LogInfo(MessageType::MSG_INFO, json));
+
+        nlohmann::json doc;
+#ifndef NO_EXCEPTIONS
+        try {
+#endif
+            doc = nlohmann::json::parse(json);
+#ifndef NO_EXCEPTIONS
+        } catch (nlohmann::detail::parse_error &errs) {
+            CleanAndLog(log, errs.what());
+            logger.LogMessage(MessageType::MSG_WARNING, log.str());
+            continue;
+        }
+#endif
+
+        LSPRet ret = HandleMessage(std::move(doc), handler);
+        if (ret == LSPRet::NORMAL_EXIT || ret == LSPRet::ABNORMAL_EXIT) {
+            return ret;
+        }
+    }
+
+    return LSPRet::NORMAL_EXIT;
+}
+
+LSPRet WasmTransport::HandleMessage(nlohmann::json message, MessageHandler &handler)
+{
+    Logger &logger = Logger::Instance();
+
+    // Message must be an object with "jsonrpc":"2.0".
+    if (message["jsonrpc"].is_null() || message.value("jsonrpc", "") != "2.0") {
+        logger.LogMessage(MessageType::MSG_WARNING, "jsonrpc is null or not 2.0.");
+        return LSPRet::ERR_JSON;
+    }
+
+    nlohmann::json id = nullptr;
+    if (!message["id"].is_null()) {
+        id = std::move(message["id"]);
+    }
+
+    // call or notify
+    if (!message["method"].is_null()) {
+        std::string method = message.value("method", "");
+
+        if (method == "exit") {
+            if (ShutdownRequested()) {
+                return LSPRet::NORMAL_EXIT;
+            }
+            return LSPRet::ABNORMAL_EXIT;
+        }
+
+        nlohmann::json params = nullptr;
+        if (message["params"].is_object()) {
+            params = std::move(message["params"]);
+        }
+
+        if (id.is_null()) {
+            return handler.OnNotify(method, std::move(params));
+        }
+        return handler.OnCall(method, std::move(params), std::move(id));
+    }
+
+    if (id.is_null()) {
+        std::stringstream log;
+        log << "No method and no response ID, message: " << message;
+        logger.LogMessage(MessageType::MSG_WARNING, log.str());
+        return LSPRet::ERR_JSON;
+    }
+
+    // reply
+    if (!message["error"].is_null()) {
+        return handler.OnReply(std::move(id),
+                               ValueOrError(ValueOrErrorCheck::ERR, DecodeError(message["error"])));
+    }
+
+    nlohmann::json jsonValue = nullptr;
+    if (!message["result"].is_null()) {
+        jsonValue = std::move(message["result"]);
+    }
+    return handler.OnReply(std::move(id), ValueOrError(ValueOrErrorCheck::VALUE, jsonValue));
+}
+
+} // namespace ark
+
+#endif // BUILD_WASM
