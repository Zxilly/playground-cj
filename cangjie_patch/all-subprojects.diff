@@ -0,0 +1,236 @@
+// Copyright (c) Huawei Technologies Co., Ltd. 2025. All rights reserved.
+// This source file is part of the Cangjie project, licensed under Apache-2.0
+// with Runtime Library Exception.
+//
+// See https://cangjie-lang.cn/pages/LICENSE for license information.
+
+#ifdef BUILD_WASM
+
+#include <emscripten.h>
+#include <emscripten/bind.h>
+#include <memory>
+#include <string>
+#include <thread>
+
+#include <cangjie/Basic/Version.h>
+
+#include "WasmTransport.h"
+#include "../languageserver/ArkLanguageServer.h"
+#include "../languageserver/logger/Logger.h"
+#include "../languageserver/capabilities/shutdown/Shutdown.h"
+#include "../languageserver/common/Utils.h"
+#include "../languageserver/index/IndexDatabase.h"
+
+using namespace Cangjie::FileUtil;
+
+namespace {
+
+// Global LSP server instance
+std::unique_ptr<ark::ArkLanguageServer> g_lspServer;
+std::unique_ptr<ark::lsp::IndexDatabase> g_indexDB;
+ark::Environment g_environment;
+bool g_initialized = false;
+bool g_serverLoopRunning = false;
+std::thread g_serverThread;
+
+// Callback function to send messages to JavaScript (proxied to main thread)
+extern "C" {
+    EMSCRIPTEN_KEEPALIVE
+    void wasmSendMessage(const char *message)
+    {
+        MAIN_THREAD_EM_ASM({
+            if (typeof Module.onLSPMessage === 'function') {
+                Module.onLSPMessage(UTF8ToString($0));
+            } else {
+                console.log('LSP Response:', UTF8ToString($0));
+            }
+        }, message);
+    }
+}
+
+} // anonymous namespace
+
+// Initialize the LSP server
+void initLSP()
+{
+    if (g_initialized) {
+        Trace::Log("LSP already initialized");
+        return;
+    }
+
+    Trace::Log("Initializing WASM LSP Server");
+
+    // Set up environment (WASM has limited environment access)
+    g_environment.cangjiePath = "/cangjie";
+    g_environment.cangjieHome = "/cangjie";
+    g_environment.runtimePath = "";
+
+    // Create index database (in-memory only for WASM)
+    g_indexDB = std::make_unique<ark::lsp::IndexDatabase>();
+    ark::CompilerCangjieProject::SetUseDB(false);
+
+    // Register WasmTransport
+    ark::TransportRegistrar<ark::Transport, ark::WasmTransport> wasmTransportRegistrar("wasm");
+    wasmTransportRegistrar.Regist();
+
+    // Set the message callback
+    ark::WasmTransport::Instance().SetMessageCallback(wasmSendMessage);
+
+    // Create the LSP server
+    g_lspServer = std::make_unique<ark::ArkLanguageServer>(
+        ark::WasmTransport::Instance(), g_environment, g_indexDB.get());
+
+    g_initialized = true;
+    Trace::Log("WASM LSP Server initialized");
+}
+
+// Initialize with custom paths
+void initLSPWithPaths(const std::string &cangjiePath, const std::string &cangjieHome)
+{
+    if (g_initialized) {
+        Trace::Log("LSP already initialized");
+        return;
+    }
+
+    Trace::Log("Initializing WASM LSP Server with custom paths");
+
+    g_environment.cangjiePath = cangjiePath;
+    g_environment.cangjieHome = cangjieHome;
+    g_environment.runtimePath = "";
+
+    g_indexDB = std::make_unique<ark::lsp::IndexDatabase>();
+    ark::CompilerCangjieProject::SetUseDB(false);
+
+    ark::TransportRegistrar<ark::Transport, ark::WasmTransport> wasmTransportRegistrar("wasm");
+    wasmTransportRegistrar.Regist();
+
+    ark::WasmTransport::Instance().SetMessageCallback(wasmSendMessage);
+
+    g_lspServer = std::make_unique<ark::ArkLanguageServer>(
+        ark::WasmTransport::Instance(), g_environment, g_indexDB.get());
+
+    g_initialized = true;
+    Trace::Log("WASM LSP Server initialized with custom paths");
+}
+
+// Process a single message from JavaScript
+// If server loop is running (async mode), just queue the message
+// Otherwise, process synchronously (not recommended, will block UI)
+void processMessage(const std::string &message)
+{
+    if (!g_initialized) {
+        EM_ASM({ console.error("LSP not initialized. Call initLSP() first."); });
+        return;
+    }
+
+    // Put message in queue
+    ark::WasmTransport::Instance().ReceiveMessage(message);
+
+    // If server loop is running, the background thread will process it
+    // Otherwise, process synchronously (blocks UI - not recommended)
+    if (!g_serverLoopRunning && g_lspServer) {
+        g_lspServer->ProcessSingleMessage();
+    }
+}
+
+// Start the LSP server loop in a separate thread (requires pthreads)
+void startServerLoop()
+{
+    if (!g_initialized) {
+        EM_ASM({ console.error("LSP not initialized. Call initLSP() first."); });
+        return;
+    }
+
+    if (g_serverLoopRunning) {
+        Trace::Log("Server loop already running");
+        return;
+    }
+
+    g_serverLoopRunning = true;
+
+    g_serverThread = std::thread([]() {
+        Trace::Log("Starting LSP server loop in background thread");
+        Cangjie::ICE::TriggerPointSetter iceSetter(Cangjie::ICE::LSP_TP);
+        ark::LSPRet exitCode = g_lspServer->Run();
+
+        g_serverLoopRunning = false;
+
+        if (exitCode == ark::LSPRet::NORMAL_EXIT) {
+            Trace::Log("LSP finished normally");
+        } else if (exitCode == ark::LSPRet::ABNORMAL_EXIT) {
+            Trace::Wlog("LSP exited abnormally");
+        }
+    });
+    g_serverThread.detach();
+
+    Trace::Log("Server loop started in background thread");
+}
+
+// Stop the LSP server
+void stopServer()
+{
+    if (!g_initialized) {
+        return;
+    }
+
+    Trace::Log("Stopping WASM LSP Server");
+    ark::WasmTransport::Instance().RequestExit();
+}
+
+// Shutdown and cleanup
+void shutdownLSP()
+{
+    if (!g_initialized) {
+        return;
+    }
+
+    Trace::Log("Shutting down WASM LSP Server");
+    stopServer();
+
+    g_lspServer.reset();
+    g_indexDB.reset();
+    g_initialized = false;
+    g_serverLoopRunning = false;
+}
+
+// Check if the server is initialized
+bool isInitialized()
+{
+    return g_initialized;
+}
+
+// Check if the server loop is running
+bool isServerLoopRunning()
+{
+    return g_serverLoopRunning;
+}
+
+// Get version information
+std::string getVersion()
+{
+    return std::string(Cangjie::CANGJIE_VERSION);
+}
+
+// Emscripten bindings to expose functions to JavaScript
+// Note: For filesystem operations, use Module.FS directly in JavaScript
+EMSCRIPTEN_BINDINGS(cangjie_lsp) {
+    emscripten::function("initLSP", &initLSP);
+    emscripten::function("initLSPWithPaths", &initLSPWithPaths);
+    emscripten::function("processMessage", &processMessage);
+    emscripten::function("startServerLoop", &startServerLoop);
+    emscripten::function("stopServer", &stopServer);
+    emscripten::function("shutdownLSP", &shutdownLSP);
+    emscripten::function("isInitialized", &isInitialized);
+    emscripten::function("isServerLoopRunning", &isServerLoopRunning);
+    emscripten::function("getVersion", &getVersion);
+}
+
+// Main function for WASM (minimal, initialization happens via embind)
+int main()
+{
+    Trace::Log("WASM LSP module loaded");
+
+    return 0;
+}
+
+#endif // BUILD_WASM
