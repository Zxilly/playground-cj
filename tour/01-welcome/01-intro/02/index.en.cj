// Cangjie combines excellent features from multiple modern languages
main() {
    // Immutable variable declaration similar to Rust/Kotlin
    let language = "Cangjie"
    
    // Type inference - the compiler automatically deduces types
    let year = 2024
    let isNew = true
    
    // String template interpolation
    println("Language: ${language}")
    println("Year: ${year}")
    println("Is new? ${isNew}")
}