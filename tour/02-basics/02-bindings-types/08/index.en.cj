main() {
    let letter: Rune = r'A'
    let chinese: Rune = r'仓'
    let emoji: Rune = r'🎉'

    println(letter)
    println(chinese)
    println(emoji)

    // Escape characters
    let newline: Rune = r'\n'
    let tab: Rune = r'\t'

    print("Hello")
    print(tab)
    print("World")
    print(newline)
}
