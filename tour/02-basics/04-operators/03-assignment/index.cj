main() {
    var x = 10
    println("初始值: ${x}")

    x += 5
    println("x += 5 => ${x}")

    x -= 3
    println("x -= 3 => ${x}")

    x *= 2
    println("x *= 2 => ${x}")

    x /= 4
    println("x /= 4 => ${x}")

    x %= 3
    println("x %%= 3 => ${x}")

    var y = 2.0
    y **= 8
    println("2.0 **= 8 => ${y}")
}
