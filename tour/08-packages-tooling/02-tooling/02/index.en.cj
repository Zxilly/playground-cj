// After running `cjpm init`, you get this project structure:
//
//   myproject/
//     cjpm.toml
//     src/
//       main.cj
//
// cjpm.toml contains:
//   [package]
//     name = "myproject"
//     cjc-version = "1.0.0"
//     version = "1.0.0"
//     output-type = "executable"

main(): Unit {
    println("Hello from cjpm project!")
}
